+                error.textContent = 'Ingresa los dos números para poder calcular.';
+                error.style.display = 'block';
+                return;
+            }
+
+            try {
+                const parametros = new URLSearchParams({ numero1, numero2, operacion });
+                const respuesta = await fetch(`/api/calculadora?${parametros.toString()}`);
+                const datos = await respuesta.json();
+
+                if (!respuesta.ok) {
+                    error.textContent = datos.mensaje || 'No se pudo realizar el cálculo.';
+                    error.style.display = 'block';
+                    return;
+                }
+
+                resultado.textContent = `${datos.numero1} ${datos.simbolo} ${datos.numero2} = ${datos.resultado}`;
