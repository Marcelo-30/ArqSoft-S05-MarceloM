@model CitasApp.Domain.Models.Paciente

<h1>Detalle del paciente</h1>

<div style="margin-bottom: 20px;">
    <a href="/Paciente" class="btn btn-primary">Pacientes</a>
    <a href="/Medico" class="btn btn-success">Médicos</a>
    <a href="/Cita" class="btn btn-warning">Citas</a>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Id:</strong> @Model.Id</p>
        <p><strong>Nombre:</strong> @Model.Nombre</p>
        <p><strong>Apellido:</strong> @Model.Apellido</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Teléfono:</strong> @Model.Telefono</p>
    </div>
</div>

<br />

<a href="/Paciente" class="btn btn-secondary">Volver</a>
<a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
<form asp-action="Eliminar" asp-route-id="@Model.Id" method="post" class="d-inline">
    <button type="submit" class="btn btn-danger" onclick="return confirm('¿Seguro que deseas eliminar este paciente? También se eliminarán sus citas.');">
        Eliminar
    </button>
</form>

<a href="/Cita/PorPaciente?pacienteId=@Model.Id" class="btn btn-warning">
    Ver citas de este paciente
</a>
